<!DOCTYPE html>
<html lang="en">
<head>
<%- include('/partials/head') %>
</head>
<body>

<%- include('/partials/header') %>

<section class="page-hero gallery">
  <div class="copy">
    <div class="crumbs"><a href="<%= rootPath %>">Home</a> &nbsp;/&nbsp; <span>Gallery</span></div>
    <h1>Moments, <em>quiet</em>.</h1>
    <div class="jp-line">写真ギャラリー　—　GALLERY</div>
  </div>
</section>

<section class="gallery">
  <div class="wrap">
    <div class="filters">
      <div class="row">
        <div class="count"><strong id="cnt">36</strong> &nbsp;photographs</div>
      </div>
    </div>
    <div class="masonry" id="grid"></div>
  </div>
</section>

<div class="lb" id="lb">
  <div class="close">✕&nbsp; Close</div>
  <div class="big" id="big"></div>
</div>

<%- include('/partials/footer') %>

<script>
const realPhotos = ['<%= rootPath %>img/IMG_0611.jpg','<%= rootPath %>img/IMG_0616.jpg','<%= rootPath %>img/IMG_0622.jpg','<%= rootPath %>img/IMG_0630.jpg','<%= rootPath %>img/IMG_0644.jpg'];

const items = [
  {cat:'ceremonies', title:'Peace Memorial Pagoda', cap:'Spring 2024', ratio:1, img:realPhotos[3]},
  {cat:'grounds',    title:'Mountain Gate',         cap:'Morning light', ratio:3, img:realPhotos[1]},
  {cat:'details',    title:'Koi Garden',            cap:'Inner courtyard', ratio:4, img:realPhotos[0]},
  {cat:'seasons',    title:'Main Hall',             cap:'After rain', ratio:2, img:realPhotos[2]},
  {cat:'grounds',    title:'Founder’s Hall',   cap:'Ryōzen Bridge', ratio:5, img:realPhotos[4]},
  {cat:'ceremonies', title:'Founding Anniversary',  cap:'April, kaizan-e', ratio:1, ph:'a'},
  {cat:'seasons',    title:'Cherry Blossoms',       cap:'Along the slope', ratio:3, ph:'b'},
  {cat:'details',    title:'Altar Detail',          cap:'Gilded lotus', ratio:2, ph:'c'},
  {cat:'ceremonies', title:'Suigyō Practice',       cap:'Winter cold', ratio:6, ph:'d'},
  {cat:'grounds',    title:'Five-Ring Gate',        cap:'Gojū-mon', ratio:4, ph:'e'},
  {cat:'seasons',    title:'Autumn Leaves',         cap:'Moss garden', ratio:1, ph:'f'},
  {cat:'details',    title:'Incense Smoke',         cap:'Morning service', ratio:3, ph:'g'},
  {cat:'ceremonies', title:'O-eshiki',              cap:'October memorial', ratio:5, ph:'a'},
  {cat:'grounds',    title:'Training Hall',         cap:'Kokū-dō · third floor', ratio:2, ph:'b'},
  {cat:'seasons',    title:'Winter Stillness',      cap:'Snow on tile', ratio:4, ph:'c'},
  {cat:'details',    title:'Daimandara',            cap:'Inner sanctuary', ratio:6, ph:'d'},
  {cat:'grounds',    title:'Dove Relief',           cap:'East façade', ratio:1, ph:'e'},
  {cat:'ceremonies', title:'Setsubun',              cap:'Bean-scattering', ratio:3, ph:'f'},
  {cat:'seasons',    title:'Summer Rain',           cap:'On the rooftiles', ratio:2, ph:'g'},
  {cat:'details',    title:'Bronze Bell',           cap:'Evening toll', ratio:4, ph:'a'},
  {cat:'ceremonies', title:'Memorial Service',      cap:'Hōyō at the altar', ratio:5, ph:'b'},
  {cat:'grounds',    title:'Peace Stone',           cap:'Heiwa Sengen-hi', ratio:1, ph:'c'},
  {cat:'seasons',    title:'Hydrangea',             cap:'Early summer', ratio:3, ph:'d', img:realPhotos[0]},
  {cat:'details',    title:'Calligraphy',           cap:'Hi-myō inscription', ratio:2, ph:'e'},
  {cat:'grounds',    title:'Dome, at Dusk',         cap:'Rooftop of the office wing', ratio:4, ph:'f'},
  {cat:'ceremonies', title:'Live Stream',           cap:'MyouTube recording', ratio:6, ph:'g'},
  {cat:'seasons',    title:'First Light',           cap:'January dawn', ratio:1, ph:'a'},
  {cat:'details',    title:'Tatami Room',           cap:'Fourth floor', ratio:3, ph:'b'},
  {cat:'grounds',    title:'Mortuary Hall',         cap:'Second-floor sanctuary', ratio:2, ph:'c'},
  {cat:'ceremonies', title:'Omizutori',             cap:'Water-drawing rite', ratio:5, ph:'d'},
  {cat:'seasons',    title:'Moon Viewing',          cap:'Autumn equinox', ratio:4, ph:'e'},
  {cat:'details',    title:'Gate Inscription',      cap:'Shōchū-zan', ratio:1, ph:'f'},
  {cat:'grounds',    title:'Inner Courtyard',       cap:'Seen from the ramp', ratio:3, ph:'g', img:realPhotos[0]},
  {cat:'ceremonies', title:'Spring Assembly',       cap:'General congregation', ratio:2, ph:'a'},
  {cat:'details',    title:'Offering',              cap:'Fresh lotus', ratio:6, ph:'b'},
  {cat:'seasons',    title:'Evening Bell',          cap:'Nightfall on the grounds', ratio:4, ph:'c'},
];

function shuffle(a){ const r = [...a]; for(let i=r.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[r[i],r[j]]=[r[j],r[i]];} return r; }
const shuffled = shuffle(items);

const grid = document.getElementById('grid');
const lb = document.getElementById('lb');
const big = document.getElementById('big');

function render(cat){
  grid.innerHTML = '';
  let n = 0;
  shuffled.forEach(it=>{
    if(cat !== 'all' && it.cat !== cat) return;
    n++;
    const el = document.createElement('div');
    el.className = `tile r${it.ratio}`;
    const bg = it.img ? `background-image:url('${it.img}')` : '';
    el.innerHTML = `
      <div class="img ${it.ph ? 'ph-'+it.ph : ''}" style="${bg}"></div>
      <div class="overlay"><div class="cap"><b>${it.title}</b>${it.cap} · ${it.cat}</div></div>
    `;
    if(it.img){
      el.addEventListener('click', ()=>{
        big.style.backgroundImage = `url('${it.img}')`;
        lb.classList.add('on');
      });
    }
    grid.appendChild(el);
  });
  document.getElementById('cnt').textContent = String(n).padStart(2,'0');
}
render('all');

lb.onclick = ()=> lb.classList.remove('on');
document.addEventListener('keydown', e=>{ if(e.key==='Escape') lb.classList.remove('on'); });
</script>
<script src="<%= rootPath %>site.js"></script>
</body>
</html>

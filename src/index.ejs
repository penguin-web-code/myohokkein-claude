<!DOCTYPE html>
<html lang="en">
<head>
<%- include('/partials/head') %>
</head>
<body>

<%- include('/partials/header') %>

<!-- HERO -->
<section class="hero" id="hero">
  <div class="slides">
    <div class="slide slide-1 active"></div>
    <div class="slide slide-2"></div>
    <div class="slide slide-3"></div>
  </div>
  <div class="hero-copy">
    <div class="wrap">
      <div>
        <div class="kicker">Gokokusan Myohokkein — Nichiren-shū · Since 1632</div>
        <h1>A quiet temple on the <em>Rokko</em> mountainside of Kobe.</h1>
        <div class="jp-line">護国山　妙法華院　—　神戸</div>
      </div>
      <div class="hero-meta">
        <strong>Hyogo-ku, Kobe</strong><br>
        7:00 — 17:00, open daily<br>
        Established 1632
      </div>
    </div>
  </div>
  <div class="hero-dots">
    <button data-idx="0" class="active"><span class="bar"></span></button>
    <button data-idx="1"><span class="bar"></span></button>
    <button data-idx="2"><span class="bar"></span></button>
  </div>
</section>

<!-- INTRO CARDS -->
<section id="about">
  <div class="wrap">
    <div class="sec-head">
      <div class="eyebrow-wrap"><span class="eyebrow">I — The Temple</span></div>
      <div>
        <h2>Step inside, at <em>your</em> own pace.</h2>
        <p class="lead">Myohokkein has stood on the slopes of Kobe for nearly four centuries — a branch temple of the Nichiren school, open to visitors, pilgrims, and the simply curious.</p>
        <div class="jp-sub">ゆっくり、ごゆっくり。</div>
      </div>
    </div>
    <div class="intro-grid">
      <a class="card m1" href="<%= rootPath %>about/">
        <div class="media"></div>
        <div class="body">
          <h3>About the temple</h3>
          <span class="jp">寺院について</span>
          <p>A Nichiren-shū branch temple in the Hyogo hills — its school, its history, and the priest who tends it.</p>
          <span class="arrow">Read more</span>
        </div>
      </a>
      <a class="card m3" href="<%= rootPath %>grounds/">
        <div class="media"></div>
        <div class="body">
          <h3>Grounds</h3>
          <span class="jp">境内</span>
          <p>A walk through the gate, the five-ring arch, the koi pond, the main hall, and the halls above.</p>
          <span class="arrow">Read more</span>
        </div>
      </a>
      <a class="card m4" href="<%= rootPath %>gallery/">
        <div class="media"></div>
        <div class="body">
          <h3>Gallery</h3>
          <span class="jp">写真</span>
          <p>Seasons, ceremonies, and quiet corners — a visual record of the temple.</p>
          <span class="arrow">View gallery</span>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- ACCESS -->
<section id="access" style="padding-top:40px">
  <div class="wrap">
    <div class="sec-head">
      <div class="eyebrow-wrap"><span class="eyebrow">II — Visit</span></div>
      <div>
        <h2>How to <em>find</em> us.</h2>
        <p class="lead">Myohokkein sits fifteen minutes' walk northwest of Shin-Kobe Station, tucked into a quiet residential street at the foot of the Rokko range. All are welcome during open hours.</p>
        <div class="jp-sub">アクセス</div>
      </div>
    </div>
    <div class="access-split">
      <div class="map-wrap">
        <iframe src="https://maps.google.com/maps?q=%E7%A5%9E%E6%88%B8%E5%B8%82%E5%85%B5%E5%BA%AB%E5%8C%BA%E6%B0%B8%E6%B2%A2%E7%94%BA4-5-8&t=&z=16&ie=UTF8&iwloc=&output=embed" loading="lazy"></iframe>
      </div>
      <div class="access-info">
        <h3>Myohokkein</h3>
        <div class="eyebrow" style="margin-top:8px">Gokokusan · Nichiren-shū</div>
        <div class="addr">
          <strong>4-5-8 Eizawa-chō, Hyogo-ku, Kobe 652-0816</strong>
          <span class="jp">〒652-0816　神戸市兵庫区永沢町4-5-8</span>
          TEL 078-575-2608<br>FAX 078-577-7651
        </div>
        <dl>
          <div class="dl-row">
            <dt>Train</dt>
            <dd>15 min on foot from <strong>Shin-Kobe Stn.</strong> (Shinkansen, Seishin-Yamate Line).<br>8 min on foot from <strong>Kōsoku Nagata Stn.</strong> (Hanshin Line).</dd>
          </div>
          <div class="dl-row">
            <dt>Bus</dt>
            <dd>City Bus 7 to <strong>Minatogawa-chō</strong>, then 5 min on foot up the hill.</dd>
          </div>
          <div class="dl-row">
            <dt>Car</dt>
            <dd>10 min from Hanshin Expressway <strong>Yanagihara IC</strong>. Small parking lot on site (4 cars).</dd>
          </div>
        </dl>
        <div class="hours">
          <h4>Opening hours</h4>
          <div class="row"><span>Gates open</span><strong>07:00</strong></div>
          <div class="row"><span>Gates close</span><strong>17:00</strong></div>
          <div class="row"><span>Temple office</span><strong>09:00 — 17:00</strong></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SOCIAL -->
<section id="social" style="padding:80px 0 60px">
  <div class="wrap">
    <div class="social-row">
      <span class="eyebrow">Follow along</span>
      <a href="https://www.instagram.com/explore/locations/236870120051032/" target="_blank" rel="noopener" class="social-link">
        <span class="sl-name">Instagram</span>
        <span class="sl-arrow">↗</span>
      </a>
      <a href="https://www.youtube.com/channel/UCNAaxCyBY_0nOeElQppw3AQ/live?app=desktop" target="_blank" rel="noopener" class="social-link">
        <span class="sl-name">YouTube</span>
        <span class="sl-arrow">↗</span>
      </a>
    </div>
  </div>
</section>

<%- include('/partials/footer') %>

<script src="<%= rootPath %>site.js"></script>
<script>
const slides = document.querySelectorAll('.hero .slide');
const dots = document.querySelectorAll('.hero-dots button');
let cur = 0, timer = null;
function show(i){
  cur = (i + slides.length) % slides.length;
  slides.forEach((s,k)=>s.classList.toggle('active',k===cur));
  dots.forEach((d,k)=>d.classList.toggle('active',k===cur));
}
function startAuto(){ stopAuto(); timer = setInterval(()=>show(cur+1), 5200); }
function stopAuto(){ if(timer){clearInterval(timer);timer=null;} }
dots.forEach(d => d.onclick = ()=>{show(+d.dataset.idx);startAuto();});
startAuto();
</script>
</body>
</html>
